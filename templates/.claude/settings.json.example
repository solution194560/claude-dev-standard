{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(python -m pytest*)",
      "Bash(python3 -m pytest*)",
      "Bash(.venv/bin/python -m pytest*)",
      "Bash(.venv/Scripts/python.exe -m pytest*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(*--apply*)",
      "Bash(*--no-dry-run*)",
      "Bash(*--yes*)",
      "Bash(git push*)",
      "PowerShell(*--apply*)",
      "PowerShell(*--no-dry-run*)",
      "PowerShell(*--yes*)",
      "PowerShell(git push*)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  }
}
